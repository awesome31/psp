# ---- Database (Neon Postgres) ----
# Use the POOLED connection string from the Neon dashboard (has "-pooler" in host).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# ---- App ----
# Public base URL of this app. Vapi posts call webhooks to APP_URL/api/webhooks/vapi.
# Locally, use an ngrok/tunnel URL so Vapi can reach your machine.
APP_URL="http://localhost:3000"

# Protects /api/cron/run. Vercel Cron sends it as "Authorization: Bearer <secret>".
CRON_SECRET="change-me-to-a-long-random-string"
# Optional: lets the "Run scheduler now" button in the UI pass the secret in dev.
NEXT_PUBLIC_CRON_SECRET="change-me-to-a-long-random-string"

# ---- Vapi ----
# Private API key from https://dashboard.vapi.ai (Settings -> API Keys).
VAPI_API_KEY="your-vapi-private-key"
# The phone number to call FROM. Provision one in Vapi (a US number is instant;
# an Indian +91 number needs KYC and takes longer). This is its ID, not the number.
VAPI_PHONE_NUMBER_ID="your-vapi-phone-number-id"

# Optional: verify webhooks. Set the same value in Vapi's server settings.
VAPI_WEBHOOK_SECRET=""

# ---- Model / voice (optional overrides; sensible defaults in code) ----
# Current Hindi/Hinglish calling setup.
VAPI_MODEL_PROVIDER="openai"
VAPI_MODEL="gpt-4o-mini"
# Text-to-speech voice.
VAPI_VOICE_PROVIDER="vapi"
VAPI_VOICE_ID="Naina"
# Optional provider-specific TTS model. Leave blank unless the voice provider needs it.
VAPI_VOICE_MODEL=""
# Speech-to-text.
VAPI_TRANSCRIBER_PROVIDER="deepgram"
VAPI_TRANSCRIBER_MODEL="nova-2"
VAPI_TRANSCRIBER_LANGUAGE="en"
